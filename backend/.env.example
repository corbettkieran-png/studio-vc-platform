# Database
DATABASE_URL=postgresql://user:password@localhost:5432/studio_vc

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=deals@studiovc.com

# File Storage
UPLOAD_DIR=./uploads
MAX_DECK_SIZE_MB=25
MAX_VIDEO_SIZE_MB=100

# Google OAuth
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorised JavaScript origins: https://deals.studiovc.com (+ http://localhost:5173 for local dev)
# No callback URL needed — uses client-side ID token verification
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Optional: restrict to specific email domains (comma-separated), e.g. studio.vc,studiovc.com
# Leave blank to allow any Google account
ALLOWED_GOOGLE_DOMAINS=

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
